# Postgres — Neon (https://neon.com/) + Drizzle ORM
# Runtime na Vercel: use a connection string **Pooled** do Neon Console.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
# Migrations locais/CI: use a connection string **Direct** (não configurar na Vercel).
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Supabase — Auth OAuth + Storage (frontend Vite; obrigatórias no build Vercel)
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
