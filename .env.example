# Postgres — Drizzle ORM (server-only; use URL com pooler na Vercel)
# Ex.: Neon pooled, Supabase pooler (porta 6543) ou PgBouncer
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/db?sslmode=require

# Supabase — Auth + Storage (frontend; necessárias no build Vercel)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
